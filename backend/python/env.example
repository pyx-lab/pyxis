# Copy this file to .env and adjust values as needed.

# Redis
REDIS_URL=redis://localhost:6379/0

# Retry behaviour
MAX_RETRIES=5
RETRY_DELAYS=0.1,0.2,0.4,0.8

# Pagination limits
TEXT_MAX_RESULTS_PER_PAGE=10
TEXT_MAX_PAGES=10

IMAGE_MAX_RESULTS_PER_PAGE=20
IMAGE_MAX_PAGES=10

VIDEO_MAX_RESULTS_PER_PAGE=20
VIDEO_MAX_PAGES=10

NEWS_MAX_RESULTS_PER_PAGE=10
NEWS_MAX_PAGES=10

BOOKS_MAX_RESULTS_PER_PAGE=10
BOOKS_MAX_PAGES=10

# Cache TTLs (seconds)
CACHE_TIMEOUT_TEXT=604800
CACHE_TIMEOUT_IMAGE=259200
CACHE_TIMEOUT_VIDEO=86400
CACHE_TIMEOUT_NEWS=3600
CACHE_TIMEOUT_BOOKS=1296000
CACHE_TIMEOUT_AUTOCOMPLETE=2592000
CACHE_TIMEOUT_INSTANT=2592000
