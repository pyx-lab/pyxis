# URL of the backend API (Flask application) that the frontend will call.
NEXT_PUBLIC_URL_BACKEND_API="http://localhost:5000"

# URL of the frontend itself (used for canonical links, OG meta tags, etc.).
NEXT_PUBLIC_URL_FRONTEND="http://localhost:3000"

# reCAPTCHA (leave empty to disable)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=